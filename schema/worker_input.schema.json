    "ArtifactType": {
      "enum": [
        "raw_user_request",
        "requirements_ir",
        "plc_code",
        "io_contract",
        "plc_project_bundle",
        "test_cases",
        "test_report",
        "failing_trace",
        "formal_properties",
        "formal_model",
        "formal_report",
        "counterexample",
        "patch",
        "repair_summary",
        "gate_report",
        "final_report",
        "worker_log",
        "main_agent_log",
        "misc"
