        "tool_name": {
          "title": "Tool Name",
          "type": "string"
        },
        "arguments": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "title": "Arguments",
          "type": "object"
        },
        "status": {
          "enum": [
            "queued",
            "running",
            "applied",
            "rejected",
            "failed",
            "no-op"
          ],
