    "QualityRequirements": {
      "additionalProperties": false,
      "properties": {
        "must_compile": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Must Compile"
