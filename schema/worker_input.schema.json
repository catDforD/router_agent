    "TaskType": {
      "enum": [
        "qa",
        "new_plc_development",
        "modify_existing_code",
        "test_existing_code",
        "formal_verify_existing_code",
        "repair_existing_code",
        "project_level_development",
        "unknown"
      ],
      "title": "TaskType",
      "type": "string"
    },
    "TraceContext": {
      "additionalProperties": false,
      "properties": {
        "openai_trace_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Openai Trace Id"
