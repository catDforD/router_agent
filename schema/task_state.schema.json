{
  "$defs": {
    "AgentRunState": {
      "additionalProperties": false,
      "properties": {
        "agent_run_id": {
          "title": "Agent Run Id",
          "type": "string"
        },
        "status": {
          "enum": [
            "running",
            "waiting_user",
            "succeeded",
            "partial_failed",
            "failed",
            "cancelled"
          ],
          "title": "Status",
          "type": "string"
        },
        "workspace": {
          "anyOf": [
            {
              "$ref": "#/$defs/WorkspaceContext"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "execution_policy": {
          "anyOf": [
            {
              "$ref": "#/$defs/ExecutionPolicy"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "tool_calls": {
          "items": {
            "$ref": "#/$defs/AgentToolCallRecord"
          },
          "title": "Tool Calls",
          "type": "array"
        },
        "started_at": {
          "format": "date-time",
          "title": "Started At",
          "type": "string"
        },
        "completed_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Completed At"
        }
      },
      "required": [
        "agent_run_id",
        "status",
        "tool_calls",
        "started_at"
      ],
      "title": "AgentRunState",
      "type": "object"
    },
    "AgentToolCallRecord": {
      "additionalProperties": false,
      "properties": {
        "tool_call_id": {
          "title": "Tool Call Id",
          "type": "string"
