    "WorkerBudget": {
      "additionalProperties": false,
      "properties": {
        "timeout_seconds": {
          "minimum": 1,
          "title": "Timeout Seconds",
          "type": "integer"
        },
        "max_iterations": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Iterations"
        },
        "max_tokens": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Tokens"
